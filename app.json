{
  "expo": {
    "name": "Ludimus",
    "slug": "ludimus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ludimus-notr-black.png",
    "scheme": "ludimus",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ludimus.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.ludimus.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/ludimus.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-web-browser"
    ],

    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f4c5d722-59ae-4c68-8f76-d2ec13daf64e"
      }
    }
  }
}
