{
  "expo": {
    "name": "Ludimus",
    "slug": "ludimus",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/images/ludimus-notr-black.png",
    "scheme": "ludimus",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ludimus.app",
      "buildNumber": "1.0.4",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.ludimus.app",
      "versionCode": 8,
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splashscreen_logo.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cabf6585-9fca-4e14-9520-62521cf6b5ab"
      }
    },
    "owner": "kurri"
  }
}
